        description: 'Premium IPTV Smarters Pro subscription service with 20,000+ live channels in 4K',
        contactPoint: {
          '@type': 'ContactPoint',
          contactType: 'customer support',
          availableLanguage: ['English', 'French', 'Arabic', 'Spanish'],
          contactOption: 'TollFree',
        },
        sameAs: ['https://t.me/yourhandle', 'https://wa.me/yournumber'],
      },
      {
        '@type': 'Product',
        name: 'IPTV Smarters Pro Subscription',
        description: 'Premium IPTV subscription with 20,000+ live channels and 100,000+ VOD movies in 4K HD quality',
        brand: { '@type': 'Brand', name: 'IPTV Smarters PRO' },
        offers: [
          {
            '@type': 'Offer',
            name: '1 Month Plan',
            price: '12.00',
            priceCurrency: 'USD',
            availability: 'https://schema.org/InStock',
            url: 'https://yoursite.com/pricing',
          },
          {
            '@type': 'Offer',
            name: '3 Months Plan',
