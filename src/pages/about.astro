---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About Us | Best IPTV Smarters Pro Provider — 20,000+ Channels & 4K Streaming',
  description:
    'IPTV Smarters PRO is the #1 IPTV Smarters Pro subscription service worldwide. 20,000+ live channels, 100,000+ VOD titles, 4K Ultra HD, 99.9% uptime, and 24/7 support. Start streaming today.',
  canonical: 'https://iptv-usa-omega.vercel.app/about',
  openGraph: {
    type: 'website',
    url: 'https://iptv-usa-omega.vercel.app/about',
    title: 'About IPTV Smarters PRO — The #1 IPTV Smarters Pro Subscription Service',
    description:
      'Discover why over 50,000 subscribers trust IPTV Smarters PRO for the best IPTV Smarters Pro experience. 20K+ channels, 4K quality, zero buffering.',
    siteName: 'IPTV Smarters PRO',
    images: [{ url: '~/assets/images/default.png' }],
  },
  twitter: {
    handle: '@streamproiptv',
    site: '@streamproiptv',
    cardType: 'summary_large_image',
    title: 'About IPTV Smarters PRO | Best IPTV Smarters Pro Service',
    description:
      '20,000+ live channels. 100,000+ VOD. 4K Ultra HD. 99.9% uptime. The best IPTV Smarters Pro subscription on the market.',
  },
  robots: {
    index: true,
    follow: true,
  },
};
---

<Layout metadata={metadata}>
  <!-- ═══════════════════════════════════════════
       JSON-LD SCHEMA — Rich SEO Signals
       Targets: Organization, AboutPage, FAQPage, BreadcrumbList
  ═══════════════════════════════════════════ -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        /* BreadcrumbList — helps Google show sitelinks */
        {
          '@type': 'BreadcrumbList',
          itemListElement: [
            {
              '@type': 'ListItem',
              position: 1,
              name: 'Home',
              item: 'https://iptv-usa-omega.vercel.app',
            },
            {
              '@type': 'ListItem',
              position: 2,
              name: 'About IPTV Smarters PRO',
              item: 'https://iptv-usa-omega.vercel.app/about',
            },
          ],
        },

        /* AboutPage */
        {
          '@type': 'AboutPage',
          '@id': 'https://iptv-usa-omega.vercel.app/about#webpage',
          name: 'About IPTV Smarters PRO — The Best IPTV Smarters Pro Provider',
          description:
            "IPTV Smarters PRO is the world's leading IPTV Smarters Pro subscription service, offering 20,000+ live channels, 100,000+ VOD titles, 4K Ultra HD streaming, and 99.9% server uptime.",
          url: 'https://iptv-usa-omega.vercel.app/about',
          inLanguage: 'en-US',
          isPartOf: { '@id': 'https://iptv-usa-omega.vercel.app/#website' },
          breadcrumb: { '@id': 'https://iptv-usa-omega.vercel.app/about#breadcrumb' },
          dateModified: new Date().toISOString().split('T')[0],
        },

        /* Organization — E-E-A-T signals */
        {
          '@type': 'Organization',
          '@id': 'https://iptv-usa-omega.vercel.app/#organization',
          name: 'IPTV Smarters PRO',
          alternateName: 'IPTV Smarters Pro',
          url: 'https://iptv-usa-omega.vercel.app',
          logo: {
            '@type': 'ImageObject',
            url: 'https://iptv-usa-omega.vercel.app/logo.png',
            width: 200,
            height: 60,
          },
          description:
            'IPTV Smarters PRO provides premium IPTV Smarters Pro subscriptions with 20,000+ live channels, 100,000+ on-demand titles, 4K Ultra HD quality, and 99.9% server uptime across 50+ global servers.',
          foundingDate: '2020',
          numberOfEmployees: { '@type': 'QuantitativeValue', value: 50 },
          slogan: 'Stream Smarter. Stream Better.',
          contactPoint: [
            {
              '@type': 'ContactPoint',
              contactType: 'customer support',
              availableLanguage: ['English', 'French', 'Arabic', 'Spanish'],
              contactOption: 'TollFree',
              hoursAvailable: {
                '@type': 'OpeningHoursSpecification',
                dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
                opens: '00:00',
                closes: '23:59',
              },
            },
          ],
          sameAs: ['https://t.me/yourhandle', 'https://wa.me/yournumber'],
          aggregateRating: {
            '@type': 'AggregateRating',
            ratingValue: '4.9',
            reviewCount: '50000',
            bestRating: '5',
            worstRating: '1',
          },
        },

        /* Service — makes the service itself indexable */
        {
          '@type': 'Service',
          '@id': 'https://iptv-usa-omega.vercel.app/#service',
          name: 'IPTV Smarters Pro Subscription',
          serviceType: 'IPTV Streaming Service',
          provider: { '@id': 'https://iptv-usa-omega.vercel.app/#organization' },
          description:
            'Premium IPTV Smarters Pro subscription giving access to 20,000+ live TV channels, 100,000+ VOD movies and series, sports, PPV events, and catch-up TV in 4K and Full HD.',
          offers: {
            '@type': 'AggregateOffer',
            priceCurrency: 'USD',
            lowPrice: '9.99',
            highPrice: '59.99',
            offerCount: '4',
          },
          hasOfferCatalog: {
            '@type': 'OfferCatalog',
            name: 'IPTV Smarters Pro Plans',
            itemListElement: [
              { '@type': 'Offer', name: '1-Month Plan', price: '9.99', priceCurrency: 'USD' },
              { '@type': 'Offer', name: '3-Month Plan', price: '19.99', priceCurrency: 'USD' },
              { '@type': 'Offer', name: '6-Month Plan', price: '34.99', priceCurrency: 'USD' },
              { '@type': 'Offer', name: '12-Month Plan', price: '59.99', priceCurrency: 'USD' },
            ],
          },
        },

        /* FAQPage — targets featured snippets */
        {
          '@type': 'FAQPage',
          '@id': 'https://iptv-usa-omega.vercel.app/about#faq',
          mainEntity: [
            {
              '@type': 'Question',
              name: 'What is IPTV Smarters Pro?',
              acceptedAnswer: {
                '@type': 'Answer',
                text: 'IPTV Smarters Pro is a popular IPTV player application that allows users to stream live TV channels, movies, and series using an M3U playlist or Xtream Codes API. IPTV Smarters PRO provides the subscription service to activate and use within the app.',
              },
            },
            {
              '@type': 'Question',
              name: 'How many channels does IPTV Smarters PRO offer?',
              acceptedAnswer: {
                '@type': 'Answer',
                text: 'IPTV Smarters PRO offers over 20,000 live TV channels from around the world, including sports, movies, news, kids, and adult entertainment, all in Full HD and 4K Ultra HD quality.',
              },
            },
            {
              '@type': 'Question',
              name: 'Does IPTV Smarters PRO work on all devices?',
              acceptedAnswer: {
                '@type': 'Answer',
                text: 'Yes. IPTV Smarters PRO works on Android, iOS, Smart TVs (Samsung, LG), Amazon Fire Stick, MAG devices, Apple TV, PC, Mac, and any device that supports the IPTV Smarters Pro app or M3U players.',
              },
            },
            {
              '@type': 'Question',
              name: 'Is there a free trial for IPTV Smarters Pro?',
              acceptedAnswer: {
                '@type': 'Answer',
                text: 'Yes. IPTV Smarters PRO offers a free 24-hour test line so you can try the service before purchasing any subscription plan.',
              },
            },
          ],
        },
      ],
    })}
  />

  <!-- ═══════════════════════════════════════════
       HERO — Primary keyword in H1
  ═══════════════════════════════════════════ -->
  <Hero
    tagline="ABOUT IPTV SMARTERS PRO"
    image={{
      src: 'https://images.unsplash.com/photo-1593359677879-a4bb92f829d1?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'IPTV Smarters Pro streaming service on multiple devices — 4K live TV channels',
    }}
  >
    <Fragment slot="title">
      The World's #1 <br />
      <span class="text-accent dark:text-white">IPTV Smarters Pro</span> Provider
    </Fragment>

    <Fragment slot="subtitle">
      IPTV Smarters PRO delivers the most complete IPTV Smarters Pro subscription on the market —
      <strong>20,000+ live channels</strong>, <strong>100,000+ VOD titles</strong>, and
      <strong>true 4K Ultra HD</strong> streaming with zero buffering and 99.9% server uptime, backed by 24/7 multilingual
      support.
    </Fragment>
  </Hero>

  <!-- ═══════════════════════════════════════════
       STATS — Trust & authority signals
  ═══════════════════════════════════════════ -->
  <Stats
    title="Why 50,000+ Subscribers Choose IPTV Smarters PRO"
    subtitle="Our numbers speak for themselves. Built for speed, stability, and scale."
    stats={[
      { title: 'Global Servers', amount: '50+' },
      { title: 'Active Subscribers', amount: '50K+' },
      { title: 'Live TV Channels', amount: '20K+' },
      { title: 'Server Uptime', amount: '99.9%' },
    ]}
  />

  <!-- ═══════════════════════════════════════════
       FEATURES3 — Keyword-rich feature copy
  ═══════════════════════════════════════════ -->
  <Features3
    title="What Makes IPTV Smarters PRO the Best IPTV Service"
    subtitle="We engineered every part of our IPTV Smarters Pro infrastructure for one goal: a flawless streaming experience on every device, every time."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Anti-Freeze & Anti-Buffer Technology',
        description:
          'Our proprietary load-balancing servers distribute traffic intelligently across 50+ global nodes, eliminating freezing and buffering even during peak sports events and PPV broadcasts.',
        icon: 'tabler:shield-check',
      },
      {
        title: '4K Ultra HD & Full HD Channels',
        description:
          'Stream thousands of IPTV Smarters Pro channels in true 4K UHD and 1080p Full HD. Compatible with all major IPTV players including IPTV Smarters Pro, TiviMate, GSE IPTV, and VLC.',
        icon: 'tabler:rocket',
      },
      {
        title: '100,000+ VOD Movies & Series',
        description:
          'Beyond live TV, enjoy an ever-growing on-demand library of over 100,000 movies and TV series, updated daily with the latest releases — all included in every IPTV Smarters Pro plan.',
        icon: 'tabler:movie',
      },
      {
        title: 'Works on All Devices',
        description:
          'IPTV Smarters PRO is fully compatible with Android, iOS, Samsung Smart TV, LG TV, Amazon Fire Stick, Apple TV, MAG Box, PC, and Mac — one subscription, all your screens.',
        icon: 'tabler:devices',
      },
      {
        title: 'Sports, PPV & Premium Channels',
        description:
          'Never miss a match. Access premium sports packages including NFL, NBA, Premier League, UFC, WWE, and Pay-Per-View events — all in HD via your IPTV Smarters Pro subscription.',
        icon: 'tabler:trophy',
      },
      {
        title: 'EPG Electronic Program Guide',
        description:
          'Full 7-day EPG (TV Guide) is included with all IPTV Smarters Pro plans, so you always know what is on and never miss your favorite shows.',
        icon: 'tabler:calendar',
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════
       STEPS2 — E-E-A-T core values copy
  ═══════════════════════════════════════════ -->
  <Steps2
    title="Our Core Values at IPTV Smarters PRO"
    subtitle="We are not just an IPTV provider — we are a streaming partner committed to quality, reliability, and your total satisfaction."
    items={[
      {
        title: 'Customer-First IPTV Experience',
        description:
          'Every IPTV Smarters Pro plan comes with 24/7 live technical support, instant activation, and a 7-day money-back guarantee. Your satisfaction is our number one priority.',
      },
      {
        title: 'Constantly Upgraded Infrastructure',
        description:
          'We invest continuously in our server network, codec optimization, and channel list updates — so your IPTV Smarters Pro subscription gets faster and better over time, not slower.',
      },
      {
        title: 'Total Transparency — No Hidden Fees',
        description:
          'No contracts. No throttling. No surprise charges. What you see on our pricing page is exactly what you pay for your IPTV Smarters Pro subscription — period.',
      },
      {
        title: 'Multi-Language & Global Coverage',
        description:
          'IPTV Smarters PRO serves customers worldwide with channels and support in English, French, Arabic, Spanish, and more. Truly global IPTV coverage for every audience.',
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════
       FEATURES2 — Support CTA with keywords
  ═══════════════════════════════════════════ -->
  <Features2
    title="24/7 IPTV Smarters Pro Support — We Are Always Here"
    tagline="DEDICATED CUSTOMER SUPPORT"
    subtitle="Whether you need help setting up IPTV Smarters Pro on your device or troubleshooting a connection issue, our expert team responds fast — day or night."
    columns={2}
    items={[
      {
        title: 'Instant Help on WhatsApp',
        description:
          'Get real-time IPTV Smarters Pro setup assistance, M3U configuration help, and troubleshooting support directly from our technical team on WhatsApp — typically within minutes.',
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: 'Support & Updates on Telegram',
        description:
          'Join our Telegram channel for live server status updates, new channel announcements, IPTV Smarters Pro setup guides, and direct one-on-one customer support.',
        icon: 'tabler:brand-telegram',
      },
    ]}
  />
</Layout>
