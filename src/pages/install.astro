            },
            {
              '@type': 'HowToStep',
              position: 3,
              name: 'Download IPTV Smarters Pro APK',
              text: 'Open Downloader, go to the URL bar and enter the official IPTV Smarters Pro APK download link. Tap Go and wait for the download to complete.',
              url: 'https://iptv-usa-omega.vercel.app/install-iptv-smarters-pro-firestick#step3',
            },
            {
              '@type': 'HowToStep',
              position: 4,
              name: 'Install the APK',
              text: 'Once downloaded, tap Install on the prompt that appears. Wait for the installation to finish, then tap Done.',
              url: 'https://iptv-usa-omega.vercel.app/install-iptv-smarters-pro-firestick#step4',
            },
            {
              '@type': 'HowToStep',
              position: 5,
              name: 'Open IPTV Smarters Pro and Add Your Playlist',
              text: 'Launch IPTV Smarters Pro. Select "Login with Xtream Codes API" or "Load Your Playlist or File/URL" and enter the M3U URL, username, password, and server URL provided by IPTV Smarters PRO.',
              url: 'https://iptv-usa-omega.vercel.app/install-iptv-smarters-pro-firestick#step5',
            },
            {
