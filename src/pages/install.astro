---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features2 from '~/components/widgets/Features2.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Note from '~/components/widgets/Note.astro';

const metadata = {
  title: 'How to Install IPTV Smarters Pro on Firestick (2025 Step-by-Step Guide)',
  description:
    'Learn how to install IPTV Smarters Pro on Amazon Firestick in minutes. Step-by-step guide covering sideloading, Downloader app, and M3U setup for IPTV Smarters PRO subscription.',
  canonical: 'https://iptv-usa-omega.vercel.app/install-iptv-smarters-pro-firestick',
  openGraph: {
    type: 'article',
    url: 'https://iptv-usa-omega.vercel.app/install-iptv-smarters-pro-firestick',
    title: 'How to Install IPTV Smarters Pro on Firestick — Full 2025 Guide',
    description:
      'Step-by-step tutorial to install IPTV Smarters Pro on any Amazon Fire TV Stick. Works on Firestick 4K, Lite, and Fire TV Cube.',
    siteName: 'IPTV Smarters PRO',
    images: [{ url: '~/assets/images/default.png' }],
  },
  twitter: {
    handle: '@streamproiptv',
    site: '@streamproiptv',
    cardType: 'summary_large_image',
    title: 'Install IPTV Smarters Pro on Firestick — 2025 Guide',
    description:
      'Full step-by-step guide to sideload and set up IPTV Smarters Pro on your Amazon Firestick with your IPTV Smarters PRO subscription.',
  },
  robots: {
    index: true,
    follow: true,
  },
};
---

<Layout metadata={metadata}>
